providers:
  - name: lmstudio
    base_url: http://mac-studio.local:1234/v1
    api_key: "lm-studio"
    models:
      - id: qwen3-coder-next-80b-8bit
        name: "Qwen3-Coder-Next (80B, 8-bit)"
      - id: qwen3.5-122b-a10b-4bit
        name: "Qwen3.5-122B-A10B (4-bit)"
      - id: qwen3.5-27b-8bit
        name: "Qwen3.5-27B (8-bit)"

  - name: ollama
    base_url: http://mac-studio.local:11434/v1
    api_key: "ollama"
    models:
      - id: qwen3.5:35b-a3b
        name: "Qwen3.5-35B-A3B"

settings:
  judge_model: "anthropic/claude-sonnet-4-6-20260514"
  parallel_tasks: 1
  timeout_seconds: 300
  warmup_requests: 2
  runs_per_task: 1
  categories:
    - tool_calling
    - coding
    - reasoning
    - writing
    - research
    - memory
    - speed
